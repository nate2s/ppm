package org.taffy.core.tests.inheritance

class ClassA
{
    (@) publicMethod1
    {
        return ("A PublicMethod1")
    }

    (@) publicMethod2
    {
        return ("A PublicMethod2")
    }

    (@) publicMethod3
    {
        return ("A PublicMethod3")
    }

    (@) callPrivateMethod1
    {
        return ([self privateMethod1])
    }

    (@) callPrivateMethod2
    {
        return ([self privateMethod2])
    }

    (@) callPrivateMethod3
    {
        return ([self privateMethod3])
    }

    @private

    (@) privateMethod1
    {
        return ("A PrivateMethod1")
    }

    (@) privateMethod2
    {
        return ("A PrivateMethod2")
    }

    (@) privateMethod3
    {
        return ("A PrivateMethod3")
    }
}
