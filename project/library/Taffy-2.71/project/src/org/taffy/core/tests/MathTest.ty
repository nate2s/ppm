package org.taffy.core.tests

import org.taffy.core.maths.Math
import org.taffy.core.maths.Number
import org.taffy.core.maths.Series

//
// Note: various arrays in this file were generated by
// generators/trigGenerator.c
//

class MathTest
{
    (@) testSqrtInteger
    {
        [Number pushDigitLimit: 100]
        result = ((sqrt(152415787532388367501905199875019052100)
                   == 12345678901234567890)
                  and sqrt(100) == 10
                  and sqrt(4) == 2)
        [Number popDigitLimit]
        return (result)
    }

    (@) testSqrtReal
    {
        return (sqrt(1.5241578750) ~= 1.23456789)
    }

    (@) testSqrtNegative
    {
        return (sqrt(-1) == i and sqrt(-4) == 2i)
    }

    (@) testLg
    {
        x = 10
        y = 12

        return (lg(x * y) ~= lg(x) + lg(y)
                and lg(x / y) ~= lg(x) - lg(y)
                and lg(4) == 2
                and lg(256) ~= 8)
    }

    (@) testLog10
    {
        x = 10
        y = 12

        return (log10(x * y) ~= log10(x) + log10(y)
                and log10(x / y) ~= log10(x) - log10(y)
                and log10(1) == 0
                and log10(100) == 2
                and log10(1000) == 3)
    }

    (@) testLog
    {
        base = 7
        x = 10
        y = 12

        return (log(base, x * y) ~= log(base, x) + log(base, y)
                and log(base, x / y) ~= log(base, x) - log(base, y)
                and log(10, 100) == 2
                and log(2, 16) ~= 4)
    }

    (@) testLn
    {
        x = 10
        y = 12

        return (ln(x * y) ~= ln(x) + ln(y)
                and ln(x / y) ~= ln(x) - ln(y)
                and ln(e) ~= 1
                and ln(1) == 0)
    }

    (@) testLnOf1
    {
        x = 1
        return (x* ln(x)^2 - 2 * x * ln(x) + 2 * x == 2)
    }

    (@) testLnOfComplex
    {
        return (ln(i) ~= 0.5PI*i
                and ln(1 + i) ~= (0.3465735902799726 + 0.7853981633974481 i)
                and ln(1 - i) ~= (0.3465735902799726 - 0.7853981633974481 i))
    }

    (@) testLnOfNegative
    {
        return (ln(-1) ~= PI * i
                and ln(-2) ~= (0.693147181 + 3.14159265 i)
                and ln(-3) ~= (1.09861229 + 3.14159265 i))
    }

    (@) testChoose
    {
        values = [10, 1, 10,
                  100, 1, 100,
                  100, 10, 17310309456440,
                  100, -1, 0,
                  -100, 10, 0]

        for (a = 0; a < [values size]; a += 3)
        {
            if (choose(values[a], values[a + 1]) != values[a + 2])
            {
                io putLine: "failure at index: #[a]"
                return (false)
            }
        }

        return (true)
    }

    (@) testSeriesPower3
    {
        success = true
        series = [Series createWithBlock: ^{<k> k^3}]
        f(n) = (n^2 * (n + 1)^2) / 4

        1 upTo: 50 do: ^{ <x>
            if (series[0, x] != f(x))
            {
                success = false
            }
        }

        return (success)
    }

    (@) testSeriesPower1
    {
        success = true
        series = [Series createWithBlock: ^{<k> k * (k + 1)}]
        f(n) = (n * (n + 1) * (n + 2)) / 3

        1 upTo: 50 do: ^{ <x>
            if (series[0, x] != f(x))
            {
                success = false
            }
        }

        return (success)
    }

    (@) testPI
    {
        [Number pushDigitLimit: 300]
        series = [Series createWithBlock: ^{<k> ((-1)^k
                                                 * ((6k)!
                                                 * (13591409 + 545140134k))
                                                / ((3k)!
                                                   * ((k)!)^3
                                                   * (640320)^(3k + 3/2)))}]
        g(x) = 1 / (12 * series[0, x])
        top = 500
        value = [[g(top) asString] substringFrom: 0 to: 155]
        other = "3.141592653589793238462643383279502884197169399375105820974944592307816406286208998628034825342117067982148086513282306647093844609550582231725359408128481"
        [Number popDigitLimit]

        if (value != other)
        {
            io put: "\n#[other]\n"
            io put: "#[value]\n"
        }

        return (value == other)
    }

    (@) testAngle0
    {
        return (arg(0) == NaN)
    }

    (@) testAngle1
    {
        return (arg(1) == 0)
    }

    (@) testAngleNegative1
    {
        return (arg(-1) == PI)
    }

    (@) testAngleI
    {
        return (arg(i) == halfPI)
    }

    (@) testAngleNegativeI
    {
        return (arg(-i) == -0.5PI)
    }

    (@) testAngleComplex
    {
        return ((arg(-0.5000000000000000 + 0.8660254037844386i)
                 ~= 2.094395102393195)
                and (arg(0.5000000000000000 + 0.8660254037844386i)
                     ~= 1.047197551196598)
                and (arg(0.5000000000000000 - 0.8660254037844386i)
                     ~= -1.047197551196598)
                and (arg(-0.5000000000000000 - 0.8660254037844386i)
                     ~= -2.094395102393195))
    }

    (@) testAngleEqualsATan
    {
        return (arg(2 + 3i) ~= atan(3 / 2))
    }

    (@) testGcd
    {
        return (gcd(10, 5) == 5
                and gcd(10, -5) == 5
                and gcd(-10, -5) == 5
                and gcd(-10, 5) == 5
                and gcd(10, 0) == 10
                and gcd(0, 10) == 10
                and gcd(1, 1) == 1
                and gcd(10, 1) == 1)
    }

    (@) testLcm
    {
        return (lcm(20, 3) == 60
                and lcm(-20, 3) == 60
                and lcm(20, -3) == 60
                and lcm(-20, -3) == 60
                and lcm(20, 0) == 0
                and lcm(0, 20) == 0
                and lcm(20, 1) == 20
                and lcm(100, 22) == 1100)
    }

    (@) testAutomaticDerive
    {
        g = derive x^2
        return (g == {2x})
    }

    (@) testAutomaticIntegrate
    {
        g = integrate x^3
        return (g == x^4 / 4)
    }

    (@) testAutomaticSimplify
    {
        g = simplify cos(x)^2 + sin(x)^2
        return (g == {1})
    }

    (@) testAutomaticIntegrateWithFunctionCall
    {
        g = integrate sin(x)
        return (g == -cos(x))
    }

    (@) testArithmeticPromotion
    {
        a = x + x
        b = x^2 + y
        c = sin(x) + x
        d = sin(y) + x

        f(x) = x + x
        g(x, y) = x^2 + y
        h(x) = sin(x) + x
        j(y, x) = sin(y) + x

        return (a == f
                and b == g
                and c == h
                and d == j)
    }
}
