class TrigonometryTest
{
    (@@) testTrigonometricFunction: _function
                            values: _values
                              name: _name
    {
        _values each: ^{ <pair>
            if (! (_function(pair[0]) ~= pair[1]))
            {
                io putLine: ("#[_name] failed at #[pair[0]]: "
                             + "wanted #[pair[1]] "
                             + "but got: #[_function(pair[0])]")
                return (false)
            }
        }

        return (true)
    }

