    (@) testFactorial
    {
        Number pushDigitLimit: 500
        factorials = [1, 1, 2, 6, 24, 120, 720, 5040, 40320, 362880, 3628800, 39916800, 479001600, 6227020800, 87178291200, 1307674368000, 20922789888000, 355687428096000, 6402373705728000, 121645100408832000, 2432902008176640000, 51090942171709440000, 1124000727777607680000, 25852016738884976640000, 620448401733239439360000, 15511210043330985984000000, 403291461126605635584000000, 10888869450418352160768000000, 304888344611713860501504000000, 8841761993739701954543616000000, 265252859812191058636308480000000, 8222838654177922817725562880000000, 263130836933693530167218012160000000, 8683317618811886495518194401280000000, 295232799039604140847618609643520000000, 10333147966386144929666651337523200000000, 371993326789901217467999448150835200000000, 13763753091226345046315979581580902400000000, 523022617466601111760007224100074291200000000, 20397882081197443358640281739902897356800000000, 815915283247897734345611269596115894272000000000, 33452526613163807108170062053440751665152000000000, 1405006117752879898543142606244511569936384000000000, 60415263063373835637355132068513997507264512000000000, 2658271574788448768043625811014615890319638528000000000, 119622220865480194561963161495657715064383733760000000000, 5502622159812088949850305428800254892961651752960000000000, 258623241511168180642964355153611979969197632389120000000000, 12413915592536072670862289047373375038521486354677760000000000, 608281864034267560872252163321295376887552831379210240000000000]
        success = true

        for (a = 0; a < 50; a++)
        {
            success = ([a factorial] == factorials[a])

            if (! success)
            {
                break
            }
        }

        Number popDigitLimit
        return (success)
    }

    (@) testNumberAndMatrix
    {
        return (3 + ||33, 1, 2|| == ||36, 4, 5||
                and 3 - ||33, 1, 2|| == ||-30, 2, 1||
                and 3 * ||33 ; 1 ; 2|| == ||99 ; 3 ; 6||
                and 20 / ||1 ; 2 ; 5|| == ||20 ; 10 ; 4||
                and 33 % ||3 ; 4 ; 10|| == ||0  ; 1 ; 3||)
    }

    (@) testAddWithObjects
    {
        f(x) = x
        matrix = ||3||
        complexy = 5i

        convertedF(x) = 3 + x
        convertedMatrix = ||6||
        convertedComplexy = 3 + 5i

        value = 3

        return (value + f == convertedF
                and value + matrix == convertedMatrix
                and value + complexy == convertedComplexy)
    }

    (@) testMinusWithObjects
    {
        f(x) = x
        matrix = ||3||
        complexy = 5i

        convertedF(x) = 3 - x
        convertedMatrix = ||0||
        convertedComplexy = 3 - 5i

        value = 3

        return (value - f == convertedF
                and value - matrix == convertedMatrix
                and value - complexy == convertedComplexy)
    }

    (@) testDivideWithObjects
    {
        f(x) = x
        matrix = ||3||
        complexy = 5i

        convertedF(x) = 3 / x
        convertedMatrix = ||1||
        convertedComplexy = -0.6i

        value = 3

        return (value / f == convertedF
                and value / matrix == convertedMatrix
                and value / complexy == convertedComplexy)
    }

    (@) testMultiplyWithObjects
    {
        f(x) = x
        matrix = ||3||
        complexy = 5i

        convertedF(x) = 3 * x
        convertedMatrix = ||9||
        convertedComplexy = 15i

        value = 3

        return (value * f == convertedF
                and value * matrix == convertedMatrix
                and value * complexy == convertedComplexy)
    }

    (@) testRaiseWithObjects
    {
        f(x) = x
        matrix = ||3||
        complexy = 5i

        convertedF(x) = 3 ^ x
        convertedMatrix = ||27||
        convertedComplexy = (0.7037573231697863 - 0.7104404479510633i)

        value = 3

        return (value ^ f == convertedF
                and value ^ matrix == convertedMatrix
                and value ^ complexy ~= convertedComplexy)
    }

    (@) testLeftShiftWithObjects
    {
        f(x) = x
        matrix = ||3, 5||
        complexy = 3 + 5i

        value = 7

        convertedFLeft(x) = 7 << x
        convertedFRight(x) = x << 7
        convertedMatrixLeft = ||value << 3, value << 5||
        convertedMatrixRight = ||3 << value, 5 << value||
        convertedComplexyLeft = (value << 3) + (value << 5) * i
        convertedComplexyRight = (3 << value) + (5 << value) * i

        return ((value << f) == convertedFLeft
                and (f << value) == convertedFRight
                and value << matrix == convertedMatrixLeft
                and matrix << value == convertedMatrixRight
                and value << complexy == convertedComplexyLeft
                and complexy << value == convertedComplexyRight)
    }

    (@) testRightShiftWithObjects
    {
        f(x) = x
        matrix = ||3, 5||
        complexy = 3 + 5i

        value = 7

        convertedFLeft(x) = 7 >> x
        convertedFRight(x) = x >> 7
        convertedMatrixLeft = ||value >> 3, value >> 5||
        convertedMatrixRight = ||3 >> value, 5 >> value||
        convertedComplexyLeft = (value >> 3) + (value >> 5) * i
        convertedComplexyRight = (3 >> value) + (5 >> value) * i

        return ((value >> f) == convertedFLeft
                and (f >> value) == convertedFRight
                and value >> matrix == convertedMatrixLeft
                and matrix >> value == convertedMatrixRight
                and value >> complexy == convertedComplexyLeft
                and complexy >> value == convertedComplexyRight)
    }

    (@) testModulusWithObjects
    {
        f(x) = x
        matrix = ||3, 5||
        complexy = 3 + 5i

        value = 7

        convertedFLeft(x) = 7 % x
        convertedFRight(x) = x % 7
        convertedMatrixLeft = ||value % 3, value % 5||
        convertedMatrixRight = ||3 % value, 5 % value||
        convertedComplexyLeft = (value % 3) + (value % 5) * i
        convertedComplexyRight = (3 % value) + (5 % value) * i

        return ((value % f) == convertedFLeft
                and (f % value) == convertedFRight
                and value % matrix == convertedMatrixLeft
                and matrix % value == convertedMatrixRight
                and value % complexy == convertedComplexyLeft
                and complexy % value == convertedComplexyRight)
    }

    (@) testAndWithObjects
    {
        f(x) = x
        matrix = ||3, 5||
        complexy = 3 + 5i

        value = 7

        convertedFLeft(x) = 7 & x
        convertedFRight(x) = x & 7
        convertedMatrix = ||value & 3, value & 5||
        convertedComplexy = value & 3 + (value & 5) * i

        return ((value & f) == convertedFLeft
                and (f & value) == convertedFRight
                and value & matrix == convertedMatrix
                and matrix & value == convertedMatrix
                and value & complexy == convertedComplexy
                and complexy & value == convertedComplexy)
    }

    (@) testOrWithObjects
    {
        f(x) = x
        matrix = ||3, 5||
        complexy = 3 + 5i

        value = 7

        convertedFLeft(x) = 7 | x
        convertedFRight(x) = x | 7
        convertedMatrix = ||value | 3, value | 5||
        convertedComplexy = value | 3 + (value | 5) * i

        return ((value | f) == convertedFLeft
                and (f | value) == convertedFRight
                and value | matrix == convertedMatrix
                and matrix | value == convertedMatrix
                and value | complexy == convertedComplexy
                and complexy | value == convertedComplexy)
    }

    (@) testChomp
    {
        return ([1 chomp] == 1
                and [1.111 chomp] == 1
                and [1.11111111111 chomp] == 1
                and [0 chomp] == 0
                and [-1 chomp] == -1
                and [-1.111 chomp] == -1
                and [-1.11111111111 chomp] == -1
                and [10000000000.1 chomp] == 10000000000)
    }

    (@) testPopDigitLimit
    {
        baseDigitLimit = [Number digitLimit]
        Number pushDigitLimit: 64
        Number pushDigitLimit: 128
        Number pushDigitLimit: 256

        return ([Number popDigitLimit] == 128
                and [Number popDigitLimit] == 64
                and [Number popDigitLimit] == baseDigitLimit)
    }

    (@) testNegativeRaise
    {
        return (-2^2 == -4)
    }

    (@) testExponentialNotation
    {
        return (3E+3 == 3000
                and 3E-3 == 0.003
                and 10E+0 == 10
                and 10E-0 == 10)
    }

    (@) testGetFractionalSize
    {
        return ([3.21 getFractionalSize] == 2
                and [-3.21 getFractionalSize] == 2
                and [10 getFractionalSize] == 0
                and [0 getFractionalSize] == 0)
    }

    (@) testNot
    {
        return (~1 == 0
                and ~0xEFFE == 0x1001
                and ~0 == 1)
    }

    (@) testFactorialOfFraction
    {
        success = false

        try
        {
            3.14!
        }
        catch (NeedIntegerException _exception)
        {
            success = ([_exception value] == 3.14)
        }
        catch (Exception _exception)
        {
            // do nothing
        }

        return (success)
    }

    (@) testNotNeedInteger
    {
        success = false

        try
        {
            ~3.14
        }
        catch (NeedIntegerException _exception)
        {
            success = ([_exception value] == 3.14)
        }
        catch (Exception _exception)
        {
            // do nothing
        }

        return (success)
    }

    (@) testPrefixNegative
    {
        return (--1 == 1
                and ---1 == -1
                and ----1 == 1)
    }

    (@) testPrefixPlus
    {
        return (+1 == 1
                and +-33 == -33
                and +3.14 == 3.14)
    }

    (@) testPrefixNegativeAndPlus
    {
        return (-+1 == -1
                and ---+1   == -1
                and -+--1   == -1
                and +---1   == -1
                and +---+1  == -1
                and +--+--1 == 1)
    }

    (@) testAsBinary
    {
        return ([239487239487 asBinary] == "0b11011111000010100011010100010100111111"
                and [3 asBinary] == "0b11"
                and [0 asBinary] == "0b0"
                and [11111111111111111111111111111111111111111111 asBinary] == "0b11111111000110010011110111100000110111000100101101001110111111111100111100100000000000000011111101011000111000111000111000111000111000111000111"
                and [1111111111111111111111111111111111111111111111111111111111111111111111 asBinary] == "0b10100100110110101000010111110111111100000011001101110101100001011111010100111011100010111101100001111110010010010000101000000100010101011100101001111011000111010111000111000111000111000111000111000111000111000111000111000111000111")
    }

    (@) testAsHex
    {
        return ([239487239487 asHex] == "0x37C28D453F"
                and [3 asHex] == "0x3"
                and [0 asHex] == "0x0"
                and [1111111111111111111111111111111111111111111111111111111111111111111111 asHex] == "0x2936A17DFC0CDD617D4EE2F61F92428115729EC75C71C71C71C71C71C7")
    }

    (@) testAsBase3
    {
        return ([239487239487 asBase: 3] == "211220011021111021210210"
                and [3 asBase: 3] == "10"
                and [0 asBase: 3] == "0")
    }

    (@) testFromHex
    {
        return (0xF == 15
                and 0xFF == 255
                and 0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF == 1606938044258990275541962092341162602522202993782792835301375
                and 0xFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF == 2582249878086908589655919172003011874329705792829223512830659356540647622016841194629645353280137831435903171972747493375)
    }

    (@) testFromBinary
    {
        return (0b1 == 1
                and 0b10 == 2
                and 0b1010101010101010101010101010101010101010101010101010101010101010101010101010101010101010101010101010 == 845100400152152934331135470250)
    }

    (@) testAsBaseNegativeOne
    {
        success = false

        try
        {
            239487239487 asBase: -1
        }
        catch (IndexOutOfBoundsException exception)
        {
            success = ([exception index] == -1)
        }
        catch (Exception exception)
        {
        }

        return success
    }

