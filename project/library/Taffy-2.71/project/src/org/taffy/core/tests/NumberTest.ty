package org.taffy.core.tests

import org.taffy.core.exception.*
import org.taffy.core.maths.Number
import org.taffy.core.maths.Series

class NumberTest
{
    (@) testAbsoluteValue1
    {
        return (1 == abs(-1))
    }

    (@) testAbsoluteValue2
    {
        return (abs(-2) == abs(-2))
    }

    (@) testAbsoluteValue3
    {
        return (abs(-2)*abs(-2) == 4)
    }

    (@) testAbsoluteValue4
    {
        return (abs(-2) != -2 and abs(-2) == 2)
    }

    (@) testWithDigitLimitWithSmallDigitLimit
    {
        return ([Number withDigitLimit: 4 do: ^{ 1 }] == false)
    }

    (@) testWithDigitLimitWithNotSmallEnoughDigitLimit
    {
        return ([Number withDigitLimit: 5 do: ^{ 1 }] == 1)
    }

    (@) testPushSmallDigitLimit
    {
        return ([Number pushDigitLimit: 4] == false
                and [Number pushDigitLimit: 1] == false)
    }

    (@) testPushAlmostSmallDigitLimit
    {
        number = [Number pushDigitLimit: 5]

        if (number == false)
        {
            return false
        }

        Number popDigitLimit
        return (number == 5)
    }

    (@) testPushPrecisionNeedIntegerException
    {
        success = false

        try
        {
            Number pushDigitLimit: 1.1234
        }
        catch (NeedIntegerException _exception)
        {
            success = ([_exception value] == 1.1234)
        }
        catch (Exception _exception)
        {
            // do nothing, but we must catch it
        }

        return (success)
    }

    (@) testPushPrecisionNeedPositiveIntegerException
    {
        success = false

        try
        {
            Number pushDigitLimit: -3
        }
        catch (NeedPositiveIntegerException _exception)
        {
            success = ([_exception value] == -3)
        }
        catch (Exception _exception)
        {
            // do nothing, but we must catch it
        }

        return (success)
    }

    (@) testAbsoluteValue4
    {
        [Number pushDigitLimit: 128]

        result = (abs(-10.123412341234) == 10.123412341234
                  and abs(-10.123412341234) != 10.123412341233)

        [Number popDigitLimit]

        return (result == true)
    }

    (@) testAdd1
    {
        return (1 + 1 == 2)
    }

    (@) testAdd2
    {
        Number pushDigitLimit: 64
        a = 10000000000000000000 + 1

        success = (a == 10000000000000000001
                   and a != 10000000000000000002)
        Number popDigitLimit
        return (success)
    }

    (@) testAdd3
    {
        [Number pushDigitLimit: 128]

        a = 100000000000000000000.000000000003
        b = a + 0.000000000003

        result = (b == 100000000000000000000.000000000006
                  and b != 100000000000000000000.000000000007)

        [Number popDigitLimit]

        return (result == true)
    }

    (@) testCeiling1
    {
        return ([3.2 ceiling] == 4)
    }

    (@) testCeiling2
    {
        return ([3 ceiling] == 3)
    }

    (@) testCeiling3
    {
        return ([3.99999 ceiling] == 4)
    }

    (@) testDecrement
    {
        a = 2
        return (a-- == 1)
    }

    (@) testDelta0
    {
        return (1.0 ~=<0> 2
                and !(1.0 ~=<0> 2.1))
    }

    (@) testDelta1
    {
        return (1.01 ~=<1> 1.02
                and !(1.0 ~=<1> 1.2))
    }

    (@) testDelta5
    {
        return (1.00001 ~=<5> 1.000001
                and !(1.00001 ~=<5> 1.0001))
    }

    (@) testDelta6
    {
        return (1 ~= 1
                and 1.0 ~= 1.0
                and 1.000001 ~= 1.000002
                and 1.000001 ~=<6> 1.000002
                and !(1.000001 ~=<6> 1.00001))
    }

    (@) testDeltaEqualsNeedIntegerException
    {
        success = false

        try
        {
            1 ~=<0.2> 2
        }
        catch (NeedIntegerException _exception)
        {
            success = ([_exception value] == 0.2)
        }
        catch (Exception _exception)
        {
            // do nothing
        }

        return (success)
    }

    (@) testDeltaEqualsCastFailure
    {
        return (! (1 ~= "asdf"))
    }

    (@) testEquality1
    {
        return (1 == 1)
    }

    (@) testEquality2
    {
        return (10000000000000000000000000 == 10000000000000000000000000
                and 10000000000000000000000000 != 10000000000000000000000001)
    }

    (@) testEquality3
    {
        return (0.00000000003 == 0.00000000003
                and 0.00000000003 != 0.00000000004)
    }

    (@) testEquality4
    {
        retval = (0.00000000000000000000000000000000000000001 == 0.00000000000000000000000000000000000000001
                  and 0.00000000000000000000000000000000000000001 != 0.00000000000000000000000000000000000000002)

        return (retval)
    }

    (@) testEquality5
    {
        return (3.0 == 3.0
                and 3.0 + 0.0000001 != 3.0)
    }

    (@) testFloor1
    {
        return ([3.2 floor] == 3)
    }

    (@) testFloor2
    {
        return ([3 floor] == 3)
    }

    (@) testFloor3
    {
        return ([3.9999999 floor] == 3)
    }

    (@) testIncrement
    {
        a = 1
        return (a++ == 2)
    }

    (@) testLargerPower
    {
        result = 3.5 ^ 8
        return (result ~= 22518.75390625)
    }

    (@) testLargestPower
    {
        [Number pushDigitLimit: 512]

        preResult = 5 ^ 32.1

        result = (preResult ~= 27348728456721152316649.99541109
                  and !(preResult ~= 27348728456721152316649.99542))

        [Number popDigitLimit]

        return (result == true)
    }

    (@) testLessThan1
    {
        return (1 < 2)
    }

    (@) testLessThan2
    {
        return (1.0 < 2.0)
    }

    (@) testLessThan3
    {
        return (1.001 < 1.002
                and !(1.0001 < 1.00001))
    }

    (@) testLessThan4
    {
        return (1.000000001 < 1.00000002)
    }

    (@) testGreaterThan1
    {
        return (2 > 1)
    }

    (@) testGreaterThan2
    {
        return (2.0 > 1.0)
    }

    (@) testGreaterThan3
    {
        return (1.002 > 1.001
                and !(1.00001 > 1.0001))
    }

    (@) testDivide
    {
        a = 10
        b = a / 2

        c = 2000000000002.2
        d = c / 2

        return (a == 10
                and b == 5
                and c == 2000000000002.2
                and d == 1000000000001.1)
    }

    (@) testDivideEquals
    {
        a = 10
        a /= 3

        b = 20
        b /= 2

        c = 2222222222222
        c /= 2

        return (a ~= 3.333333333
                and b == 10
                and c == 1111111111111)
    }

    (@) testMultiplyEquals
    {
        a = 3
        a *= 3

        b = 3
        b *= 3.5

        return (a == 9 and b ~= 10.5)
    }

    (@) testMultiply1
    {
        return (3 * 4 == 12)
    }

    (@) testMultiply2
    {
        return (3.1 * 4 == 12.4)
    }

    (@) testMultiply3
    {
        return (3.7 * 4444444444 ~= 16444444442.7999999999)
    }

    (@) testMultiply4
    {
        result = (3.7 * 4444444444 ~= 16444444442.8)

        return (result == true)
    }

    (@) testPlusLong
    {
        a = 1
        b = 1
        c = -2

        return (a + b == 2 and a + c == -1)
    }

    (@) testPlusEquals
    {
        a = 1
        a += 2

        b = 1
        b += 0.3

        return (a == 3 and b ~= 1.3)
    }

    (@) testPlusSmallFractional
    {
        a = 1.2
        b = 2.3
        c = -2.5
        d = -2.2

        return (a + b == 3.5
                and a + c == -1.3
                and a + d == -1)
    }

    (@) testPlusWhole
    {
        a = 1111111111111111
        b = 2222222222222222
        c = 3333333333333333

        return (a + b == c
                and c - b == a)
    }

    (@) testPlusLargerFractional
    {
        a = 1.1111111111111
        b = 2.2222222222222
        c = 3.3333333333333
        d = 0.9999999999999
        f = 3.2222222222221

        result = ((a + b ~=<16> c)
                  and !(a + b ~=<16> d)
                  and (c - b ~=<16> a)
                  and !(c - b ~=<16> d)
                  and (b + d ~=<16> f))

        return (result == true)
    }

    (@) testRaise1
    {
        return (2^2 == 4)
    }

    (@) testRaise2
    {
        return (10^10 == 10000000000)
    }

    (@) testRaise3
    {
        return (2.2^4 ~= 23.4256)
    }

    (@) testRaise4
    {
        return (2.2^4.2 ~= 27.426807)
    }

    (@) testRaise5
    {
        [Number pushDigitLimit: 128]
        result = (22.2^3.4 ~= 37809.428517)
        [Number popDigitLimit]
        return (result == yes)
    }

    (@) testRaise6
    {
        [Number pushDigitLimit: 128]
        result = (3453^2.2 ~= 60818047.347131)
        [Number popDigitLimit]
        return (result == yes)
    }

    (@) testRaise7
    {
        Number pushDigitLimit: 1024
        result = (30^300 == 
                and 30^300 != 
                and 30^300 != .1
                and 30^300 ~= .000000000001)
        Number popDigitLimit
        return (result)
    }

    (@) testRaise8
    {
        return (3.3^4.234234234 ~= 156.859011936)
    }

    (@) testRaise9
    {
        [Number pushDigitLimit: 128]

        result = (33.3^4.234234234 ~= 2795023.687726)
        result2 = !(33.3^4.234234234 ~= 2795023.687728)

        [Number popDigitLimit]

        return (result and result2)
    }

    (@) testRaise10
    {
        return ([Number withDigitLimit: 100
                                    do: ^{(2^3^4 == 2417851639229258349412352)}])
    }

    (@) testSubtractEqual
    {
        a = 3
        a -= 1

        b = 3
        b -= 0.1

        return (a == 2 and b == 2.9)
    }

    (@) testSubtract1
    {
        a = 0.1 - 0.1
        return (a == 0)
    }

    (@) testSubtract2
    {
        return (20 - 10 == 10)
    }

    (@) testSubtract3
    {
        return (20.0000000003 - 10 ~= 10.0000000003
                and !(20.0000000003 - 10 ~= 10.000003))
    }

    (@) testSmallPower
    {
        return (3.2^3 ~= 32.768
                and !(3.2^3 ~= 32.767))
    }

    (@) testFloorLoopy
    {
        a = 0
        x = 1
        result = true

        while (a < 99)
        {
            x = x + 0.01

            if (floor(x) != 1)
            {
                result = false
                break
            }

            a++
        }

        x = x + 0.1

        if (floor(x) != 2)
        {
            result = false
        }

        return (result)
    }

    (@) testCeilingLoopy
    {
        a = 0
        x = 1
        result = true

        while (a < 99)
        {
            x = x + 0.01

            if (ceiling(x) != 2)
            {
                result = false
                break
            }

            a++
        }

        x = x + 0.1

        if (ceiling(x) != 3)
        {
            result = false
        }

        return (result)
    }

    (@) testUpTo
    {
        number = 1
        totalValue = 0

        number upTo: 100 do: ^{ <val>
            totalValue += val
        }

        return (totalValue == floor((100*101)/2))
    }

    (@) testUpToBreak
    {
        number = 1
        totalValue = 0

        number upTo: 100 do: ^{ <value>
            totalValue += value

            if (value == 10)
            {
                break
            }
        }

        return (totalValue == floor((10*11)/2))
    }

    (@) testDownTo
    {
        number = 100
        totalValue = 0

        number downTo: 1 do: ^{ <value>
            totalValue += value
        }

        return (totalValue == floor((100*101)/2))
    }

    (@) testDownToBreak
    {
        number = 100
        totalValue = 0

        number downTo: 1 do: ^{ <value>
            totalValue += value

            if (value == 90)
            {
                break
            }
        }

        adder = [Series createWithBlock: ^{<x> x}]
        return (totalValue == adder[90, 100])
    }

    (@) testOr
    {
        return (3 | 4 == 7 and 4 | 4 == 4 and 4 | 0 == 4)
    }

    (@) testOrWithBinary
    {
        return (0b00011 | 0b11000 == 0b11011
                and 0b10011 | 0b11000 == 0b11011)
    }

    (@) testOrWithHex
    {
        return (0xF0 | 0x0F == 0xFF
                and 0xFF | 0x0F == 0xFF
                and 0x00 | 0xFF == 0xFF)
    }

    (@) testOrWithExceptionCatch1
    {
        success = false

        try
        {
            3.3 | 4
        }
        catch (NeedIntegerException _exception)
        {
            success = ([_exception value] == 3.3)
        }

        return (success)
    }

    (@) testOrWithExceptionCatch2
    {
        success = false

        try
        {
            3 | 4.3
        }
        catch (NeedIntegerException _exception)
        {
            success = ([_exception value] == 4.3)
        }

        return (success)
    }

    (@) testOrWithExceptionCatch3
    {
        success = false

        try
        {
            3.3 | 4.3
        }
        catch (NeedIntegerException _exception)
        {
            success = ([_exception value] == 3.3)
        }

        return (success)
    }

    (@) testModulusSimple
    {
        return (32 % 10 == 2 and 30 % 10 == 0)
    }

    (@) testModulusDivideByZeroExceptionCatch
    {
        success = false

        try
        {
            1000 % (1-1)
        }
        catch (DivideByZeroException _exception)
        {
            success = true
        }

        return (success)
    }

    (@) testModulusEquals
    {
        a = 101
        a %= 100
        return (a == 1)
    }

    (@) testModulusEqualsDivideByZeroExceptionCatch
    {
        success = false

        try
        {
            a = 101
            a %= 0
        }
        catch (DivideByZeroException _exception)
