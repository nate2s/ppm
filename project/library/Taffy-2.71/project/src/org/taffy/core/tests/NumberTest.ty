    {
        success = false

        try
        {
            1.1 << 1
        }
        catch (NeedIntegerException _exception)
        {
            success = ([_exception value] == 1.1)
        }

        return (success)
    }

    (@) testLeftShiftException3
    {
        success = false

        try
        {
            1.1 << 1.1
        }
        catch (NeedIntegerException _exception)
        {
            success = ([_exception value] == 1.1)
        }

        return (success)
    }

    (@) testLeftShiftEqual
    {
        a = 1
        a <<= 10
        return (a == 1024)
    }

    (@) testLeftShiftEqualException
    {
        success = false

        try
        {
            a = 1
            a <<= 1.1
        }
        catch (NeedIntegerException _exception)
        {
            success = ([_exception value] == 1.1)
        }

        return (success)
    }

    (@) testRightShift
    {
        return (0b0001 >> 1 == 0b0000
                and 0b0000 >> 31 == 0b0000
                and 0b1000 >> 2 == 0b0010
                and 0xFF00 >> 1 == 0x7F80
                and 0xFF00 >> -8 == 0xFF0000
                and 2 >> 0 == 2
                and 0 >> 0 == 0)
    }

    (@) testRightShiftException1
    {
        success = false

        try
        {
            1 >> 1.1
        }
        catch (NeedIntegerException _exception)
        {
