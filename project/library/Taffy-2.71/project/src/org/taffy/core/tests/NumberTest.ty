            success = true
        }

        return (success)
    }

    (@) testLeftShift
    {
        return (0b0001 << 1 == 0b0010
                and 0b0000 << 31 == 0b0000
                and 0b0100 << 0 == 0b0100
                and 0x00FF << 8 == 0xFF00
                and 0xFF00 << -8 == 0x00FF
                and 2 << 3 == 16)
    }

    (@) testLeftShiftException1
    {
        success = false

        try
        {
            1 << 1.1
        }
        catch (NeedIntegerException _exception)
        {
            success = ([_exception value] == 1.1)
        }

        return (success)
    }

