    (@@) testFormattedNumber: _left
                       right: _right
                       style: _style
                     success: _success
    {
        result = false

        try
        {
            number = [Number formattedNumber: _left style: _style]
            result = (number == _right)
        }
        catch (InvalidFormattedNumberException _exception)
        {
            result = ! _success
        }
        catch (Exception _exception)
        {
            io putLine: "got exception: #[_exception]"
        }

        return result
    }

    (@) testAmericanFormattedNumber
    {
        numbers = ["1,345,456,678.12345", 1345456678.12345, true,
                   "1,345,456",           1345456,          true,
                   "345.145",             345.145,          true,
                   "3.145",               3.145,            true,
                   "3.1",                 3.1,              true,
                   "3",                   3,                true,
                   "0.2",                 0.2,              true,
                   "4,1",                 nil,              false,
                   "1.234.234",           nil,              false,
                   "1,3456,234",          nil,              false,
                   "1,3.2",               nil,              false]

       for (a = 0; a < [numbers size]; a += 3)
       {
           if (! [NumberTest testFormattedNumber: numbers[a]
                                           right: numbers[a + 1]
                                           style: 'american
                                         success: numbers[a + 2]])
           {
               io putLine: "failed at index: #[a]"
               return false
           }
       }

       return true
    }

    (@) testBritishFormattedNumber
    {
        numbers = ["1.345.456.678,12345", 1345456678.12345, true,
                   "1.345.456",           1345456,          true,
                   "345,145",             345.145,          true,
                   "3,145",               3.145,            true,
                   "3,1",                 3.1,              true,
                   "3",                   3,                true,
                   "0,2",                 0.2,              true,
                   "4.1",                 nil,              false,
                   "1,234,234",           nil,              false,
                   "1,3456,234",          nil,              false,
                   "1,3.2",               nil,              false]

       for (a = 0; a < [numbers size]; a += 3)
       {
           if (! [NumberTest testFormattedNumber: numbers[a]
                                           right: numbers[a + 1]
                                           style: 'british
                                         success: numbers[a + 2]])
           {
               io putLine: "failed at index: #[a]"
               return false
           }
       }

       return true
    }

    (@) testUnwholeDenomitorLarge
    {
        f(x) = 1 / 0.00001693508780843028671103659672475401784958255008552219343257294789073481346000779014039187793188707683
        display = [f asString]
        f simplify!
        return (display == [f asString])
    }

    (@) testMetaPrint
    {
        return ([Number asString] == "#Number-meta")
    }
}
