        return success
    }

    (@) testAsBaseSelfFractional
    {
        success = false

        try
        {
            1.25 asBase: 3
        }
        catch (NeedIntegerException exception)
        {
            success = ([exception value] == 1.25)
        }
        catch (Exception exception)
